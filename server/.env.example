# Whitelist server configuration. Copy to .env and fill in.

# HTTP port
PORT=4000

# Stellar network (must match a deployments/<network>/deployments.json)
STELLAR_NETWORK=testnet

# ASP admin signer: EITHER an identity name from `stellar keys ls`...
STELLAR_ADMIN_IDENTITY=pollar-asp-admin
# ...OR a raw secret key (do NOT commit this file with a real key)
# STELLAR_ADMIN_SECRET=S...

# Optional overrides
# STELLAR_BIN=stellar
# LEAF_CLI=../target/release/asp-leaf-cli
# DATA_FILE=./whitelist.json
